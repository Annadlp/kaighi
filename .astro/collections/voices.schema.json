{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "title": {
      "type": "string"
    },
    "date": {
      "type": "string",
      "format": "date-time"
    },
    "language": {
      "default": "ru",
      "type": "string",
      "enum": [
        "ru",
        "en"
      ]
    },
    "guestName": {
      "type": "string"
    },
    "guestBio": {
      "type": "string"
    },
    "audioEmbedUrl": {
      "type": "string"
    },
    "buzzsproutPodcastId": {
      "type": "string"
    },
    "buzzsproutEpisodeId": {
      "type": "string"
    },
    "shortDescription": {
      "type": "string"
    },
    "heroQuote": {
      "type": "string"
    },
    "coverImage": {
      "type": "string"
    },
    "episodeNumber": {
      "type": "number"
    },
    "duration": {
      "type": "string"
    },
    "keyQuotes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "guestbookPrompt": {
      "type": "string"
    },
    "$schema": {
      "type": "string"
    }
  },
  "required": [
    "title",
    "date"
  ]
}