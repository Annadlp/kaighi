{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "name": {
      "type": "string"
    },
    "location": {
      "type": "string"
    },
    "date": {
      "type": "string",
      "format": "date-time"
    },
    "language": {
      "default": "ru",
      "type": "string",
      "enum": [
        "ru",
        "en"
      ]
    },
    "$schema": {
      "type": "string"
    }
  },
  "required": [
    "name",
    "date"
  ]
}