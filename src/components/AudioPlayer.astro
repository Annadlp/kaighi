---
interface Props {
  src?: string;
  embedUrl?: string;
  title?: string;
}
const { src, embedUrl, title = 'Аудио' } = Astro.props;
---

<div class="audio-player-container">
  <p class="meta">Слушать выпуск</p>
  {embedUrl ? (
    <iframe
      src={embedUrl}
      width="100%"
      height="180"
      frameborder="0"
      scrolling="no"
      title={title}
      style="border: none;"
    ></iframe>
  ) : src ? (
    <audio controls>
      <source src={src} type="audio/mpeg" />
      Ваш браузер не поддерживает аудио.
    </audio>
  ) : (
    <p style="color:var(--muted);font-size:14px;">Аудио появится здесь.</p>
  )}
</div>
