---
import { getCollection, render } from 'astro:content';
import MainLayout from '../../layouts/MainLayout.astro';
import AudioPlayer from '../../components/AudioPlayer.astro';

export async function getStaticPaths() {
  const entries = await getCollection('voices', ({ data }) => data.language === 'ru');
  return entries.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
---

<MainLayout title={entry.data.title} description={entry.data.shortDescription} lang="ru">
  <article class="article">
    <header class="article-header">
      <p class="kicker" data-editable="text" data-prop="guestName">Голоса / {entry.data.guestName}</p>
      <h1 data-editable="text" data-prop="title">{entry.data.title}</h1>
      <p class="meta">
        {entry.data.date.toLocaleDateString('ru-RU', { year: 'numeric', month: 'long', day: 'numeric' })}
      </p>
      <p class="article-lead" data-editable="text" data-prop="shortDescription">{entry.data.shortDescription}</p>
    </header>

    {entry.data.audioEmbedUrl && <AudioPlayer url={entry.data.audioEmbedUrl} title={entry.data.title} />}

    {entry.data.heroQuote && (
      <blockquote class="pullquote" data-editable="text" data-prop="heroQuote">«{entry.data.heroQuote}»</blockquote>
    )}

    {entry.data.guestBio && (
      <section class="band">
        <div>
          <p class="section-kicker">О героине</p>
          <h2>{entry.data.guestName}</h2>
        </div>
        <p data-editable="text" data-prop="guestBio">{entry.data.guestBio}</p>
      </section>
    )}

    <div class="prose">
      <Content />
    </div>

    {entry.data.guestbookPrompt && (
      <section class="band">
        <div>
          <p class="section-kicker">Вопрос</p>
          <h2>Оставить след</h2>
        </div>
        <div>
          <p>{entry.data.guestbookPrompt}</p>
          <a class="button-link" href="/guestbook">Открыть гостевую</a>
        </div>
      </section>
    )}
  </article>
</MainLayout>
