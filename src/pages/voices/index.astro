---
import { getCollection } from 'astro:content';
import MainLayout from '../../layouts/MainLayout.astro';

const voices = (await getCollection('voices'))
  .filter(v => v.data.language === 'ru')
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const fmt = (d: Date) =>
  d.toLocaleDateString('ru-RU', { day: 'numeric', month: 'long', year: 'numeric' });
---

<MainLayout title="Голоса">
  <div class="page-header">
    <span class="meta">Раздел</span>
    <h1>Голоса</h1>
    <p>Подкасты, разговоры и записи — память, которая звучит голосом.</p>
  </div>

  <div class="voice-list">
    {voices.map((v, i) => (
      <article class="voice-card">
        <div class="voice-card-img">
          <img
            src={v.data.coverImage ?? '/uploads/kaighi-hero.png'}
            alt={v.data.title}
          />
          {v.data.episodeNumber && (
            <span class="voice-card-ep">Эп. {v.data.episodeNumber}</span>
          )}
        </div>

        <div class="voice-card-body">
          <span class="meta">{fmt(v.data.date)}</span>
          <h2><a href={`/voices/${v.id}`}>{v.data.title}</a></h2>
          {v.data.guestName && (
            <span class="voice-guest">{v.data.guestName}</span>
          )}
          {v.data.shortDescription && (
            <p>{v.data.shortDescription}</p>
          )}
          <div class="voice-card-footer">
            <a class="read-link" href={`/voices/${v.id}`}>Слушать →</a>
            {v.data.duration && (
              <span class="voice-duration">{v.data.duration}</span>
            )}
          </div>
        </div>
      </article>
    ))}
  </div>
</MainLayout>
