---
import { getCollection } from 'astro:content';
import MainLayout from '../layouts/MainLayout.astro';

const entries = (await getCollection('guestbook'))
  .filter(e => e.data.language === 'ru')
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const fmt = (d: Date) =>
  d.toLocaleDateString('ru-RU', { day: 'numeric', month: 'long', year: 'numeric' });
---

<MainLayout title="Контакты">
  <div class="page-header">
    <h1>Контакты</h1>
    <p>Напишите нам или оставьте след в гостевой книге.</p>
  </div>

  <section class="contact-section" style="margin-top: 0; border-top: none; padding-top: 0;">
    <p class="contact-intro">
      Есть вопросы или предложения? Напишите, используя эту форму.
    </p>
    <form class="contact-form" onsubmit="return false">
      <div class="contact-left">
        <label>
          <span>Имя</span>
          <input name="name" type="text" autocomplete="name" />
        </label>
        <label>
          <span>Почта</span>
          <input name="email" type="email" autocomplete="email" />
        </label>
        <button type="button">Отправить</button>
      </div>
      <label class="message-field">
        <span>Сообщение</span>
        <textarea name="message" rows="5"></textarea>
      </label>
    </form>
  </section>

  {entries.length > 0 && (
    <section style="margin-top: 52px;">
      <p class="section-kicker">Гостевая книга</p>
      <div class="guestbook-entries">
        {entries.map(e => (
          <div class="guestbook-entry">
            <span class="meta">
              {e.data.name}
              {e.data.location && ` · ${e.data.location}`}
              {` · ${fmt(e.data.date)}`}
            </span>
            <p>{e.body?.trim()}</p>
          </div>
        ))}
      </div>
    </section>
  )}
</MainLayout>
