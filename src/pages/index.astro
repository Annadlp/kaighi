---
import MainLayout from '../layouts/MainLayout.astro';

const sideItems = [
  { title: 'Наукан и море',               image: '/uploads/kaighi-hero.png', href: '/stories/naukan-i-more' },
  { title: 'Наукан — граница двух миров', image: '/uploads/kaighi-hero.png', href: '/stories/granitsa-dvukh-mirov' },
  { title: 'Память о доме',               image: '/uploads/mom.png',          href: '/stories/pamyat-o-dome' },
];

const storyItems = [
  { title: 'Наукан — граница двух миров', image: '/uploads/kaighi-hero.png', href: '/stories/granitsa-dvukh-mirov', excerpt: 'Наукан стоял на самом краю Евразии — там, где Чукотка смотрит на Аляску через узкий пролив.' },
  { title: 'Наукан и море',               image: '/uploads/kaighi-hero.png', href: '/stories/naukan-i-more',        excerpt: 'Вся жизнь моего народа — эскимосов нувукахми — была связана с морем.' },
  { title: 'Память о доме',               image: '/uploads/mom.png',          href: '/stories/pamyat-o-dome',       excerpt: 'Что значит помнить место, которого больше нет?' },
];
---

<MainLayout title="Главная" isHome={true}>

  <section class="hero-shell" aria-label="Kaighi">
    <div class="wing-layer" aria-hidden="true"></div>

    <h1 class="site-logo" aria-label="KAIGHI">
      <span>K</span><span>A</span><span>I</span><span>G</span><span>H</span><span>I</span>
    </h1>
    <p class="site-subtitle">общественная яранга на краю земли</p>

    <div class="hero-grid">
      <article class="hero-feature">
        <img src="/uploads/kaighi-hero.png" alt="Наукан" />
        <p class="meta">28 мая 2022 г.</p>
        <h2>О Каиги</h2>
        <p>
          <strong>Kaighi</strong> — цифровая общественная яранга для голосов,
          историй, рецептов и памяти эскимосского народа нувукахми.
        </p>
        <p>
          Здесь можно слушать подкасты, читать рассказы, собирать семейные
          рецепты и возвращать имена, слова и следы Наукана.
        </p>
      </article>

      <aside class="hero-list" aria-label="Последние материалы">
        {sideItems.map((item) => (
          <a class="hero-card" href={item.href}>
            <img src={item.image} alt="" />
            <div>
              <p class="meta">28 мая 2022 г.</p>
              <h3>{item.title}</h3>
            </div>
          </a>
        ))}
      </aside>
    </div>
  </section>

  <section class="story-section" aria-labelledby="stories-heading">
    <p class="section-kicker" id="stories-heading">Истории и рассказы</p>
    <div class="story-grid">
      {storyItems.map((item) => (
        <article class="story-card">
          <a href={item.href}>
            <img src={item.image} alt="" />
          </a>
          <p class="meta">28 мая 2022 г.</p>
          <h2><a href={item.href}>{item.title}</a></h2>
          <p>{item.excerpt}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="scheme-section" aria-labelledby="scheme-title">
  <p class="outline-title">Схема</p>
  <h2 id="scheme-title">Наукана</h2>

  <div class="map-credit">
    <p>
      Эта карта Наукана воспроизведена по рисунку науканского археолога,
      этнографа и писателя <strong>Тасяна Теина</strong>.
    </p>
  </div>

  <img
    class="naukan-map"
    src="/images/map.svg"
    alt="Карта Наукана"
  />
</section>


  <section class="contact-section" aria-labelledby="contact-heading">
    <p class="contact-intro">
      Есть вопросы или предложения? Напишите автору сайта, используя эту форму.
    </p>
    <form class="contact-form" onsubmit="return false">
      <div class="contact-left">
        <label>
          <span>Имя</span>
          <input name="name" type="text" autocomplete="name" />
        </label>
        <label>
          <span>Почта</span>
          <input name="email" type="email" autocomplete="email" />
        </label>
        <button type="button">Отправить</button>
      </div>
      <label class="message-field">
        <span id="contact-heading">Сообщение</span>
        <textarea name="message" rows="5"></textarea>
      </label>
    </form>
  </section>

</MainLayout>