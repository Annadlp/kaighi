---
import { getCollection } from 'astro:content';
import MainLayout from '../layouts/MainLayout.astro';

const allStories = (await getCollection('stories'))
  .filter(s => s.data.language === 'ru')
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const allVoices = (await getCollection('voices'))
  .filter(v => v.data.language === 'ru')
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const allRecipes = (await getCollection('table'))
  .filter(r => r.data.language === 'ru')
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const heroStories = allStories.slice(0, 4);
const featuredStory = allStories[0];
const gridStories = allStories.slice(0, 3);

const fmt = (d: Date) =>
  d.toLocaleDateString('ru-RU', { day: 'numeric', month: 'long', year: 'numeric' });
---

<MainLayout title="Главная">

  <!-- ── Hero ─────────────────────────────────────────────── -->
  <section class="home-hero" aria-label="Главное">
    <div class="hero-grid">

      <!-- Большое фото слева -->
      <div class="hero-main">
        <img
          src={featuredStory?.data.heroImage ?? '/uploads/kaighi-hero.png'}
          alt={featuredStory?.data.title ?? 'Каиги'}
        />
      </div>

      <!-- Стек статей справа -->
      <div class="hero-stack">
        {heroStories.map(story => (
          <a class="hero-card" href={`/stories/${story.id}`}>
            <div class="hero-card-thumb">
              <img
                src={story.data.heroImage ?? '/uploads/kaighi-hero.png'}
                alt={story.data.title}
              />
            </div>
            <div class="hero-card-body">
              <span class="meta">{fmt(story.data.date)}</span>
              <h3>{story.data.title}</h3>
            </div>
          </a>
        ))}
      </div>

    </div>
  </section>

  <!-- ── О Каиги ───────────────────────────────────────────── -->
  <section class="about-section" aria-labelledby="about-title">
    <div class="about-grid">
      <div class="about-left">
        <span class="meta">{fmt(featuredStory?.data.date ?? new Date())}</span>
        <h2 id="about-title">О KAIGHI</h2>
      </div>
      <div class="about-text">
        <p>
          <strong>Kaighi</strong> (нувукахми, «каиги» — общественная яранга)&thinsp;—
          заброшенный эскимосский посёлок на мысе Дежнёва.
        </p>
        <p>
          До 1958 года являлся самым восточным поселением Евразии, но затем
          уступил это звание Узлену. Ныне в качестве урочища входит в российскую
          часть природно-этнического парка «Берингия» (участок «Узлен»).
        </p>
      </div>
    </div>
  </section>

  <!-- ── Истории и рассказы ─────────────────────────────────── -->
  <section class="section" aria-labelledby="stories-title">
    <div class="section-head">
      <p class="section-kicker">Истории и рассказы</p>
      <h2 id="stories-title" class="section-title">Голоса, рассказы и стол</h2>
    </div>

    <div class="entry-grid">
      {gridStories.map(story => (
        <article class="entry-card">
          <a href={`/stories/${story.id}`}>
            <div class="entry-card-img">
              <img
                src={story.data.heroImage ?? '/uploads/kaighi-hero.png'}
                alt={story.data.title}
              />
            </div>
          </a>
          <span class="meta">{fmt(story.data.date)}</span>
          <h3><a href={`/stories/${story.id}`}>{story.data.title}</a></h3>
          {story.data.intro && <p>{story.data.intro}</p>}
          <a class="button-link" href={`/stories/${story.id}`}>Читать</a>
        </article>
      ))}
    </div>
  </section>

  <!-- ── Схема Каиги ────────────────────────────────────────── -->
  <section class="band" aria-labelledby="schema-title">
    <div>
      <p class="section-kicker">Схема</p>
      <h2 id="schema-title">Каиги</h2>
    </div>
    <div>
      <p>
        Kaighi можно читать как архив, слушать как подкаст, открывать как
        семейную книгу и пополнять как место, куда возвращаются имена,
        рецепты и слова.
      </p>
      <a class="button-link" href="/guestbook">Оставить след в гостевой</a>
    </div>
  </section>

  <!-- ── Форма связи ─────────────────────────────────────────── -->
  <section class="contact-grid" aria-labelledby="contact-title">
    <div class="contact-left">
      <p class="contact-intro">Есть вопросы или предложения? Напишите автору сайта, используя эту форму.</p>

      <div class="form-field">
        <label class="form-label" for="contact-name">Имя</label>
        <input class="form-input" id="contact-name" type="text" name="name" autocomplete="name" />
      </div>

      <div class="form-field">
        <label class="form-label" for="contact-email">Почта</label>
        <input class="form-input" id="contact-email" type="email" name="email" autocomplete="email" />
      </div>

      <button class="form-submit" type="submit">Отправить</button>
    </div>

    <div class="form-field">
      <label class="form-label" for="contact-message">Сообщение</label>
      <textarea class="form-textarea" id="contact-message" name="message" rows="8"></textarea>
    </div>
  </section>

</MainLayout>
