---
import MainLayout from '../layouts/MainLayout.astro';

const featured = {
  type: 'Подкаст',
  date: '1 июня 2026 г.',
  title: 'Помочь словом: радио, язык и память',
  image: '/uploads/mom.png',
  href: '/voices/pomoch-slovom-radio-yazyk-i-pamyat',
  excerpt:
    'Айвана Энмынкау разговаривает со своей мамой Ниной Энмынкау о её работе на радио, языке и памяти.',
};

const updates = [
  { type: 'Голоса', date: '1 июня 2026 г.', title: 'Помочь словом: радио, язык и память', image: '/uploads/mom.png', href: '/voices/pomoch-slovom-radio-yazyk-i-pamyat' },
  { type: 'Истории', date: '28 мая 2022 г.', title: 'Наукан — граница двух миров', image: '/uploads/kaighi-hero.png', href: '/stories/granitsa-dvukh-mirov' },
  { type: 'Истории', date: '28 мая 2022 г.', title: 'Наукан и море', image: '/uploads/kaighi-hero.png', href: '/stories/naukan-i-more' },
  { type: 'Истории', date: '28 мая 2022 г.', title: 'Память о доме', image: '/uploads/mom.png', href: '/stories/pamyat-o-dome' },
  { type: 'Стол', date: 'скоро', title: 'Рецепты, вкус и память', image: '/uploads/kaighi-hero.png', href: '/table' },
  { type: 'Предания ночи', date: 'скоро', title: 'Ночные истории Наукана', image: '/uploads/kaighi-hero.png', href: '/night' },
];

const explainers = [
  { title: 'Что такое Каиги', image: '/uploads/kaighi-hero.png', href: '/about/kaighi', excerpt: 'Цифровая общественная яранга для голосов, историй, рецептов и памяти нувукахми.' },
  { title: 'Что такое Наукан', image: '/uploads/kaighi-hero.png', href: '/about/naukan', excerpt: 'Поселение на краю Евразии, место памяти, языка и родовых историй.' },
  { title: 'Кто такой Тасян Теин', image: '/uploads/mom.png', href: '/about/tasyan-tein', excerpt: 'Науканский археолог, этнограф и писатель, сохранивший Наукан на бумаге.' },
];
---

<MainLayout title="Главная" isHome={true}>
  <section class="home-hero" aria-label="Kaighi">
    <div class="home-mark">
      <h1 class="home-logo" aria-label="KAIGHI">KAIGHI</h1>
      <p class="home-subtitle">общественная яранга на краю земли</p>
      <div class="home-wing" aria-hidden="true"></div>
    </div>

    <div class="home-top-grid">
      <article class="home-feature">
        <a href={featured.href}>
          <img src={featured.image} alt="" />
        </a>
        <p class="meta">{featured.type} · {featured.date}</p>
        <h2><a href={featured.href}>{featured.title}</a></h2>
        <p>{featured.excerpt}</p>
        <a class="text-link" href={featured.href}>Слушать историю →</a>
      </article>

      <aside class="home-updates" aria-label="Последние обновления">
        {updates.map((item) => (
          <a class="update-card" href={item.href}>
            <img src={item.image} alt="" />
            <div>
              <p class="meta">{item.type} · {item.date}</p>
              <h3>{item.title}</h3>
            </div>
          </a>
        ))}
      </aside>
    </div>
  </section>

  <section class="newsletter" aria-label="Подписка на рассылку">
    <div class="newsletter-copy">
      <p class="section-label">Рассылка</p>
      <h2>Новые голоса, истории и предания</h2>
    </div>

    <form class="newsletter-form" onsubmit="return false">
      <input type="email" name="email" placeholder="Ваша почта" />
      <button type="button">Подписаться</button>
    </form>
  </section>

  <section class="home-section" aria-labelledby="explainers-title">
    <p class="section-label" id="explainers-title">Объясняем</p>

    <div class="three-grid">
      {explainers.map((item) => (
        <article class="info-card">
          <a href={item.href}>
            <img src={item.image} alt="" />
          </a>
          <h2><a href={item.href}>{item.title}</a></h2>
          <p>{item.excerpt}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="home-section map-section" aria-labelledby="map-title">
    <p class="section-label">Схема</p>
    <h2 id="map-title">Наукана</h2>
    <p class="map-credit">
      Эта карта Наукана воспроизведена по рисунку науканского археолога,
      этнографа и писателя <strong>Тасяна Теина</strong>.
    </p>
    <img class="naukan-map" src="/images/map.svg" alt="Карта Наукана" />
  </section>

  <section class="contact-section" aria-labelledby="contact-heading">
    <p class="contact-intro">
      Есть вопросы или предложения? Напишите автору сайта, используя эту форму.
    </p>

    <form class="contact-form" onsubmit="return false">
      <div class="contact-left">
        <label>
          <span>Имя</span>
          <input name="name" type="text" autocomplete="name" />
        </label>
        <label>
          <span>Почта</span>
          <input name="email" type="email" autocomplete="email" />
        </label>
        <button type="button">Отправить</button>
      </div>

      <label class="message-field">
        <span id="contact-heading">Сообщение</span>
        <textarea name="message" rows="5"></textarea>
      </label>
    </form>
  </section>
</MainLayout>
