---
import MainLayout from '../layouts/MainLayout.astro';

const sideItems = [
  { title: 'Наукан и море', image: '/uploads/kaighi-hero.png' },
  { title: 'Наукан — граница двух миров', image: '/uploads/kaighi-hero.png' },
  { title: 'Память о доме', image: '/uploads/mom.png' },
  { title: 'Голоса с края земли', image: '/uploads/kaighi-hero.png' },
];

const storyItems = [
  { title: 'Наукан — граница двух миров', image: '/uploads/kaighi-hero.png' },
  { title: 'Наукан и море', image: '/uploads/kaighi-hero.png' },
  { title: 'Память о доме', image: '/uploads/mom.png' },
];
---

<MainLayout title="Главная" lang="ru">
  <section class="hero-shell" aria-label="Kaighi">
    <div class="wing-layer" aria-hidden="true"></div>

    <h1 class="site-logo" aria-label="KAIGHI">
      <span>K</span><span>A</span><span>I</span><span>G</span><span>H</span><span>I</span>
    </h1>

    <p class="site-subtitle">общественная яранга на краю земли</p>

    <div class="hero-grid">
      <article class="hero-feature">
        <img src="/uploads/kaighi-hero.png" alt="Наукан" />
        <p class="meta">28 мая 2022 г.</p>
        <h2>О Каиги</h2>
        <p><strong>Kaighi</strong> — цифровая общественная яранга для голосов, историй, рецептов и памяти.</p>
        <p>Здесь можно слушать подкасты, читать рассказы, собирать семейные рецепты и возвращать имена, слова и следы Наукана.</p>
      </article>

      <aside class="hero-list" aria-label="Последние материалы">
        {sideItems.map((item) => (
          <a class="hero-card" href="/stories">
            <img src={item.image} alt="" />
            <div>
              <p class="meta">28 мая 2022 г.</p>
              <h3>{item.title}</h3>
            </div>
          </a>
        ))}
      </aside>
    </div>
  </section>

  <section class="story-section" aria-labelledby="stories-title">
    <p class="section-kicker">Истории и рассказы</p>
    <div class="story-grid">
      {storyItems.map((item) => (
        <article class="story-card">
          <img src={item.image} alt="" />
          <p class="meta">28 мая 2022 г.</p>
          <h2>{item.title}</h2>
          <p><strong>Наукан</strong> — место на краю земли, где память держится в голосах, маршрутах, еде и рассказах.</p>
        </article>
      ))}
    </div>
  </section>

  <section class="scheme-section" aria-labelledby="scheme-title">
    <p class="outline-title">Схема</p>
    <h2 id="scheme-title">Каиги</h2>
    <div class="scheme-map" aria-hidden="true">
      <div class="map-line line-one"></div>
      <div class="map-line line-two"></div>
      <div class="map-line line-three"></div>
      <div class="map-dots"></div>
    </div>
  </section>

  <section class="contact-section" aria-labelledby="contact-title">
    <p class="contact-intro">Есть вопросы или предложения? Напишите автору сайта, используя эту форму.</p>
    <form class="contact-form">
      <div class="contact-left">
        <label>
          <span>Имя</span>
          <input name="name" />
        </label>
        <label>
          <span>Почта</span>
          <input name="email" />
        </label>
        <button type="button">Отправить</button>
      </div>
      <label class="message-field">
        <span id="contact-title">Сообщение</span>
        <textarea name="message"></textarea>
      </label>
    </form>
  </section>
</MainLayout>
