---
import { getCollection, render } from 'astro:content';
import NightLayout from '../../layouts/NightLayout.astro';

export async function getStaticPaths() {
  const tales = await getCollection('night');
  return tales.map(t => ({ params: { slug: t.id }, props: { tale: t } }));
}

const { tale } = Astro.props;
const { Content } = await render(tale);

const fmt = (d: Date) =>
  d.toLocaleDateString('ru-RU', { day: 'numeric', month: 'long', year: 'numeric' });
---

<NightLayout title={tale.data.title} description={tale.data.intro}>
  <div class="night-article-wrap">

    <header class="night-article-header">
      <span class="meta">{fmt(tale.data.date)}</span>
      <h1>{tale.data.title}</h1>
      {tale.data.intro && (
        <p class="night-article-lead">{tale.data.intro}</p>
      )}
    </header>

    <div class="night-prose">
      <Content />
    </div>

    {tale.data.tags && tale.data.tags.length > 0 && (
      <div class="article-tags" style="border-top-color: var(--nl); margin-top: 36px; padding-top: 22px;">
        {tale.data.tags.map(t => (
          <span class="tag" style="border-color: rgba(199,173,120,.4); color: var(--ng);">
            {t}
          </span>
        ))}
      </div>
    )}

    <a class="night-back" href="/night">← Все предания</a>

  </div>
</NightLayout>
