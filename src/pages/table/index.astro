---
import { getCollection } from 'astro:content';
import MainLayout from '../../layouts/MainLayout.astro';

const recipes = (await getCollection('table'))
  .filter(r => r.data.language === 'ru')
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const fmt = (d: Date) =>
  d.toLocaleDateString('ru-RU', { day: 'numeric', month: 'long', year: 'numeric' });
---

<MainLayout title="Стол">
  <div class="page-header">
    <span class="meta">Раздел</span>
    <h1>Стол</h1>
    <p>Еда как место, где простые вещи держат семью и память.</p>
  </div>

  <div class="card-grid">
    {recipes.map(r => (
      <article class="media-card">
        <a href={`/table/${r.id}`}>
          <div class="media-card-img">
            <img
              src={r.data.heroImage ?? '/uploads/kaighi-hero.png'}
              alt={r.data.title}
            />
          </div>
        </a>
        <span class="meta">{fmt(r.data.date)}</span>
        <h2><a href={`/table/${r.id}`}>{r.data.title}</a></h2>
        {r.data.shortMemory && <p>{r.data.shortMemory}</p>}
        <a class="read-link" href={`/table/${r.id}`}>Сесть за стол →</a>
      </article>
    ))}
  </div>
</MainLayout>
