---
import { getCollection } from 'astro:content';
import MainLayout from '../../layouts/MainLayout.astro';

const recipes = await getCollection('table', ({ data }) => data.language === 'ru');
const sortedRecipes = recipes.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<MainLayout title="Стол" lang="ru">
  <section class="page-hero" data-editable="source" data-path="/src/pages/table/index.astro" data-key="hero">
    <p class="kicker">Kaighi / рецепты памяти</p>
    <h1>Стол</h1>
    <p>Еда, домашние рецепты и маленькие истории о том, как память остается теплой.</p>
  </section>

  <section class="list-grid" aria-label="Рецепты памяти">
    {sortedRecipes.map((recipe) => (
      <article class="list-card">
        <p class="meta">
          {recipe.data.date.toLocaleDateString('ru-RU', { year: 'numeric', month: 'long' })}
        </p>
        <h2><a href={`/table/${recipe.id}`}>{recipe.data.title}</a></h2>
        <p>{recipe.data.shortMemory}</p>
        <a class="button-link" href={`/table/${recipe.id}`}>Открыть рецепт</a>
      </article>
    ))}
  </section>
</MainLayout>
