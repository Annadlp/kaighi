---
import { getCollection, render } from 'astro:content';
import MainLayout from '../../layouts/MainLayout.astro';

export async function getStaticPaths() {
  const recipes = await getCollection('table');
  return recipes.map(r => ({ params: { slug: r.id }, props: { recipe: r } }));
}

const { recipe } = Astro.props;
const { Content } = await render(recipe);

const fmt = (d: Date) =>
  d.toLocaleDateString('ru-RU', { day: 'numeric', month: 'long', year: 'numeric' });
---

<MainLayout title={recipe.data.title} description={recipe.data.shortMemory}>
  <div class="article-wrap">

    <header class="article-header">
      <span class="meta">{fmt(recipe.data.date)}</span>
      <h1>{recipe.data.title}</h1>
      {recipe.data.shortMemory && (
        <p class="article-lead">{recipe.data.shortMemory}</p>
      )}
    </header>

    {recipe.data.heroImage && (
      <div class="article-hero">
        <img src={recipe.data.heroImage} alt={recipe.data.title} />
      </div>
    )}

    <div class="recipe-detail">
      {recipe.data.ingredients && recipe.data.ingredients.length > 0 && (
        <aside class="ingredients">
          <span class="ingredients-title">Ингредиенты</span>
          <ul>
            {recipe.data.ingredients.map(i => <li>{i}</li>)}
          </ul>
        </aside>
      )}

      <div class="prose">
        {recipe.data.method && (
          <p><strong>Способ приготовления:</strong> {recipe.data.method}</p>
        )}
        <Content />
      </div>
    </div>

    {recipe.data.tags && recipe.data.tags.length > 0 && (
      <div class="article-tags">
        {recipe.data.tags.map(t => <span class="tag">{t}</span>)}
      </div>
    )}

  </div>
</MainLayout>
