---
import { getCollection, render } from 'astro:content';
import MainLayout from '../../layouts/MainLayout.astro';

export async function getStaticPaths() {
  const stories = await getCollection('stories');
  return stories.map(s => ({ params: { slug: s.id }, props: { story: s } }));
}

const { story } = Astro.props;
const { Content } = await render(story);

const fmt = (d: Date) =>
  d.toLocaleDateString('ru-RU', { day: 'numeric', month: 'long', year: 'numeric' });

const pq = story.data.pullQuotes ?? [];
---

<MainLayout title={story.data.title} description={story.data.intro}>
  <div class="article-wrap">

    <header class="article-header">
      <div class="article-socials">
        <a href="#" aria-label="Instagram">◎</a>
        <a href="#" aria-label="Facebook">f</a>
        <a href="#" aria-label="Twitter">𝕏</a>
      </div>
      <span class="meta">{fmt(story.data.date)}</span>
      <h1>{story.data.title}</h1>
      {story.data.intro && <p class="article-lead">{story.data.intro}</p>}
    </header>

    {story.data.heroImage && (
      <div class="article-hero">
        <img src={story.data.heroImage} alt={story.data.title} />
      </div>
    )}

    {pq[0] && (
      <aside class="inline-quote">
        „{pq[0]}"
        <a
          class="inline-quote-tweet"
          href={`https://twitter.com/intent/tweet?text=${encodeURIComponent('"' + pq[0] + '" — Kaighi')}`}
          target="_blank"
          rel="noopener noreferrer"
        >
          Твитнуть
        </a>
      </aside>
    )}

    <div class="prose">
      <Content />
    </div>

    {pq[1] && <blockquote class="pullquote">{pq[1]}</blockquote>}

    {story.data.tags && story.data.tags.length > 0 && (
      <div class="article-tags">
        {story.data.tags.map(t => <span class="tag">{t}</span>)}
      </div>
    )}

  </div>
</MainLayout>
