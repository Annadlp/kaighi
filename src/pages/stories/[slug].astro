---
import { getCollection, render } from 'astro:content';
import MainLayout from '../../layouts/MainLayout.astro';

export async function getStaticPaths() {
  const entries = await getCollection('stories', ({ data }) => data.language === 'ru');
  return entries.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const typeLabel = entry.data.type === 'essay' ? 'Эссе' : entry.data.type === 'memory' ? 'Память' : 'История';
---

<MainLayout title={entry.data.title} description={entry.data.intro} lang="ru">
  <article class="article">
    <header class="article-header">
      <p class="kicker">{typeLabel}</p>
      <h1 data-editable="text" data-prop="title">{entry.data.title}</h1>
      <p class="meta">
        {entry.data.date.toLocaleDateString('ru-RU', { year: 'numeric', month: 'long' })}
      </p>
      {entry.data.intro && <p class="article-lead" data-editable="text" data-prop="intro">{entry.data.intro}</p>}
    </header>

    {entry.data.heroImage && (
      <figure class="article-image">
        <img src={entry.data.heroImage} alt={entry.data.title} data-editable="image" data-prop="heroImage" />
      </figure>
    )}

    <div class="prose">
      <Content />
    </div>

    {entry.data.tags.length > 0 && (
      <div class="tags">
        {entry.data.tags.map((tag) => <span class="tag">#{tag}</span>)}
      </div>
    )}
  </article>
</MainLayout>
