---
import { getCollection } from 'astro:content';
import MainLayout from '../../layouts/MainLayout.astro';

const stories = await getCollection('stories', ({ data }) => data.language === 'ru');
const sortedStories = stories.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<MainLayout title="Истории" lang="ru">
  <section class="page-hero" data-editable="source" data-path="/src/pages/stories/index.astro" data-key="hero">
    <p class="kicker">Kaighi / читать</p>
    <h1>Истории</h1>
    <p>Рассказы, эссе, семейные фрагменты и тексты, которые держат память.</p>
  </section>

  <section class="list-grid" aria-label="Истории">
    {sortedStories.map((story) => (
      <article class="list-card">
        <p class="meta">
          {story.data.type === 'essay' ? 'эссе' : story.data.type === 'memory' ? 'память' : 'история'} · {story.data.date.toLocaleDateString('ru-RU', { year: 'numeric', month: 'long' })}
        </p>
        <h2><a href={`/stories/${story.id}`}>{story.data.title}</a></h2>
        {story.data.intro && <p>{story.data.intro}</p>}
        <a class="button-link" href={`/stories/${story.id}`}>Читать</a>
      </article>
    ))}
  </section>
</MainLayout>
