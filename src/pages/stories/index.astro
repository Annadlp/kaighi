---
import { getCollection } from 'astro:content';
import MainLayout from '../../layouts/MainLayout.astro';

const stories = (await getCollection('stories'))
  .filter(s => s.data.language === 'ru')
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const fmt = (d: Date) =>
  d.toLocaleDateString('ru-RU', { day: 'numeric', month: 'long', year: 'numeric' });
---

<MainLayout title="Истории">
  <div class="page-header">
    <span class="meta">Раздел</span>
    <h1>Истории</h1>
    <p>Рассказы о доме, дороге, языке, женщинах, смехе и памяти.</p>
  </div>

  <div class="card-grid">
    {stories.map(s => (
      <article class="media-card">
        <a href={`/stories/${s.id}`}>
          <div class="media-card-img">
            <img
              src={s.data.heroImage ?? '/uploads/kaighi-hero.png'}
              alt={s.data.title}
            />
          </div>
        </a>
        <span class="meta">{fmt(s.data.date)}</span>
        <h2><a href={`/stories/${s.id}`}>{s.data.title}</a></h2>
        {s.data.intro && <p>{s.data.intro}</p>}
        <a class="read-link" href={`/stories/${s.id}`}>Читать →</a>
      </article>
    ))}
  </div>
</MainLayout>
