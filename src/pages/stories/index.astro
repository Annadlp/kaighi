---
import { getCollection } from 'astro:content';
import MainLayout from '../../layouts/MainLayout.astro';

const stories = (await getCollection('stories'))
  .filter(s => s.data.language === 'ru')
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const fmt = (d: Date) =>
  d.toLocaleDateString('ru-RU', { day: 'numeric', month: 'long', year: 'numeric' });
---

<MainLayout title="Истории">
  <div class="page-hero">
    <span class="meta">Раздел</span>
    <h1>Истории</h1>
    <p class="page-hero-lead">
      Рассказы о доме, дороге, языке, женщинах, смехе и памяти.
    </p>
  </div>

  <div class="list-grid">
    {stories.map(story => (
      <article class="list-card">
        <a href={`/stories/${story.id}`}>
          <div class="list-card-img">
            <img
              src={story.data.heroImage ?? '/uploads/kaighi-hero.png'}
              alt={story.data.title}
            />
          </div>
        </a>
        <span class="meta">{fmt(story.data.date)}</span>
        <h2><a href={`/stories/${story.id}`}>{story.data.title}</a></h2>
        {story.data.intro && <p>{story.data.intro}</p>}
        <a class="button-link" href={`/stories/${story.id}`}>Читать</a>
      </article>
    ))}
  </div>
</MainLayout>
