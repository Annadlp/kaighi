---
import '../global.css';

interface Props {
  title: string;
  description?: string;
  lang?: 'ru' | 'en';
}

const {
  title,
  description = 'Kaighi — цифровая общественная яранга: голоса, истории, еда и семейная память.',
  lang = 'ru',
} = Astro.props;

const currentPath = Astro.url.pathname.replace(/\/$/, '') || '/';
const isActive = (href: string) => {
  const clean = href.replace(/\/$/, '') || '/';
  return currentPath === clean || (clean !== '/' && currentPath.startsWith(clean + '/'));
};

const nav = [
  { href: '/about', label: 'О Каиги' },
  { href: '/voices', label: 'Голоса' },
  { href: '/stories', label: 'Истории' },
  { href: '/table', label: 'Стол' },
  { href: '/night', label: 'Предания ночи' },
  { href: '/guestbook', label: 'Контакты' },
];
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title} | Kaighi</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans:wght@400;500;600;700&family=IBM+Plex+Serif:wght@400;500;600&display=swap" rel="stylesheet" />
  </head>
  <body class="day-shell">
    <header class="site-header">
      <nav class="site-nav" aria-label="Главная навигация">
        {nav.map((item) => (
          <a class="nav-link" href={item.href} aria-current={isActive(item.href) ? 'page' : undefined}>
            {item.label}
          </a>
        ))}
      </nav>
      <a class="site-logo" href="/" aria-label="Kaighi home">КАИГИ</a>
      <p class="site-subtitle">общественная яранга на краю земли</p>
    </header>

    <main class="site-main">
      <slot />
    </main>

    <footer class="site-footer">
      <div class="footer-copy">
        <div class="footer-mark">◌◌◌</div>
        <p>© {new Date().getFullYear()} Kaighi.</p>
        <p>Копирование любых материалов сайта возможно только с разрешения правообладателя.</p>
      </div>
      <div>
        <h2>Разделы</h2>
        <a href="/voices">Голоса</a>
        <a href="/stories">Истории</a>
        <a href="/table">Стол</a>
        <a href="/guestbook">Контакты</a>
      </div>
      <div>
        <h2>Подписка</h2>
        <form class="subscribe-form">
          <input aria-label="Email" />
          <button type="button">Подписаться</button>
        </form>
        <div class="socials" aria-label="Социальные ссылки">
          <span>f</span><span>◎</span><span>𝕏</span><span>in</span>
        </div>
      </div>
    </footer>
  </body>
</html>
