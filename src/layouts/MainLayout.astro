---
import '../global.css';

interface Props {
  title: string;
  description?: string;
  lang?: 'ru' | 'en';
}

const {
  title,
  description = 'Kaighi — цифровая общественная яранга: голоса, истории, еда и семейная память.',
  lang = 'ru',
} = Astro.props;

const currentPath = Astro.url.pathname.replace(/\/$/, '') || '/';
const isActive = (href: string) => {
  const clean = href.replace(/\/$/, '') || '/';
  return currentPath === clean || (clean !== '/' && currentPath.startsWith(clean + '/'));
};

const nav = [
  { href: '/about',    label: 'О Каиги' },
  { href: '/voices',   label: 'Голоса' },
  { href: '/stories',  label: 'Истории' },
  { href: '/table',    label: 'Стол' },
  { href: '/night',    label: 'Предания ночи' },
  { href: '/guestbook',label: 'Контакты' },
];
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title} | Kaighi</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans:ital,wght@0,400;0,500;0,700;1,400&family=IBM+Plex+Serif:ital,wght@0,400;0,600;1,400;1,600&display=swap" rel="stylesheet" />
  </head>
  <body class="day-shell">

    <header class="site-header">
      <nav class="site-nav" aria-label="Главная навигация">
        {nav.map((item) => (
          <a class="nav-link" href={item.href} aria-current={isActive(item.href) ? 'page' : undefined}>
            {item.label}
          </a>
        ))}
      </nav>

      <a class="site-logo" href="/" aria-label="Kaighi — на главную">KAIGHI</a>
      
    </header>

    <main class="site-main">
      <slot />
    </main>

    <footer class="site-footer">
      <div class="footer-copy">
        <div class="footer-mark">◌◌◌</div>
        <p>© {new Date().getFullYear()} Kaighi.</p>
        <p>Копирование любых материалов сайта возможно только с разрешения правообладателя.</p>
        <p><a href="/about">Политика конфиденциальности</a></p>
      </div>

      <div>
        <h2>Разделы</h2>
        <a href="/about">О Каиги</a>
        <a href="/voices">Голоса</a>
        <a href="/stories">Истории</a>
        <a href="/table">Стол</a>
        <a href="/night">Предания ночи</a>
        <a href="/guestbook">Контакты</a>
      </div>

      <div>
        <h2>Подписка</h2>
        <form class="subscribe-form" onsubmit="return false">
          <input type="email" aria-label="Email для подписки" placeholder="ваш@email.ru" />
          <button type="submit">Подписаться</button>
        </form>
        <div class="socials" aria-label="Социальные сети">
          <a href="#" aria-label="Facebook">f</a>
          <a href="#" aria-label="Instagram">◎</a>
          <a href="#" aria-label="Twitter / X">𝕏</a>
          <a href="#" aria-label="LinkedIn">in</a>
        </div>
      </div>
    </footer>

  </body>
</html>
